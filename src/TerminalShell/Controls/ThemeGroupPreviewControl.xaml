<UserControl x:Class="TerminalShell.Controls.ThemeGroupPreviewControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TerminalShell.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400">
    <UserControl.Resources>
        <Style x:Key="PreviewSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#202124"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style x:Key="PreviewCaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8A8A8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>
        <Style x:Key="PreviewButtonBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style x:Key="PreviewKindPanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </UserControl.Resources>

    <Grid Width="400" HorizontalAlignment="Right">
        <Grid.Resources>
            <Style x:Key="WindowSessionPanelStyle" TargetType="Grid" BasedOn="{StaticResource PreviewKindPanelStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding PreviewKind, ElementName=Root}" Value="{x:Static vm:ThemePreviewKind.WindowSession}">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="InputPanelStyle" TargetType="Grid" BasedOn="{StaticResource PreviewKindPanelStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding PreviewKind, ElementName=Root}" Value="{x:Static vm:ThemePreviewKind.Input}">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="WaitPanelStyle" TargetType="Grid" BasedOn="{StaticResource PreviewKindPanelStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding PreviewKind, ElementName=Root}" Value="{x:Static vm:ThemePreviewKind.WaitForUserInput}">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ButtonsPanelStyle" TargetType="Grid" BasedOn="{StaticResource PreviewKindPanelStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding PreviewKind, ElementName=Root}" Value="{x:Static vm:ThemePreviewKind.Buttons}">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="MenusPanelStyle" TargetType="Grid" BasedOn="{StaticResource PreviewKindPanelStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding PreviewKind, ElementName=Root}" Value="{x:Static vm:ThemePreviewKind.MenusAndIntelliSense}">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid Style="{StaticResource WindowSessionPanelStyle}">
            <Border Style="{StaticResource PreviewSurfaceStyle}">
                <StackPanel>
                    <TextBlock Text="Live Preview" Style="{StaticResource PreviewCaptionStyle}"/>
                    <Border Margin="0,10,0,0"
                            Background="{Binding ThemeState.WindowBackgroundBrush, ElementName=Root}"
                            BorderBrush="#17181A"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14">
                        <Grid>
                            <Border BorderBrush="{Binding ThemeState.SessionBorderBrush, ElementName=Root}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="{Binding ThemeState.SessionHeaderBackgroundBrush, ElementName=Root}"
                                            Padding="10,8"
                                            CornerRadius="4,4,0,0">
                                        <DockPanel>
                                            <TextBlock Text="terminal-1"
                                                       Foreground="{Binding ThemeState.SessionHeaderForegroundBrush, ElementName=Root}"
                                                       FontWeight="SemiBold"/>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Fill="{Binding ThemeState.SessionHeaderForegroundBrush, ElementName=Root}" Opacity="0.35"/>
                                                <Ellipse Width="8" Height="8" Fill="{Binding ThemeState.SessionHeaderForegroundBrush, ElementName=Root}" Opacity="0.35" Margin="6,0,0,0"/>
                                                <Ellipse Width="8" Height="8" Fill="{Binding ThemeState.SessionHeaderForegroundBrush, ElementName=Root}" Opacity="0.35" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                    <Border Grid.Row="1" Background="#121315" Padding="10" CornerRadius="0,0,4,4">
                                        <TextBlock Text="PS D:\project_TerminalShell&gt;"
                                                   Foreground="#CFCFCF"
                                                   FontFamily="Consolas"
                                                   FontSize="12"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Width="18"
                                    Height="18"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,4,4"
                                    Background="{Binding ThemeState.ResizeHandleHoverBrush, ElementName=Root}"
                                    CornerRadius="2"
                                    Opacity="0.92"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Style="{StaticResource InputPanelStyle}">
            <Border Style="{StaticResource PreviewSurfaceStyle}">
                <StackPanel>
                    <TextBlock Text="Live Preview" Style="{StaticResource PreviewCaptionStyle}"/>
                    <Border Margin="0,10,0,0"
                            Background="{Binding ThemeState.InputContainerBackgroundBrush, ElementName=Root}"
                            BorderBrush="#3E3E42"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Command Input" Foreground="#B8B8B8" FontSize="11"/>
                            <Border Margin="0,8,0,0"
                                    Background="{Binding ThemeState.InputTextBoxBackgroundBrush, ElementName=Root}"
                                    BorderBrush="{Binding ThemeState.InputTextBoxBorderBrush, ElementName=Root}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock Text="dotnet test src/TerminalShell.sln -c Release"
                                               Foreground="{Binding ThemeState.InputTextBoxForegroundBrush, ElementName=Root}"
                                               FontFamily="Consolas"
                                               FontSize="12"/>
                                    <TextBlock Text="Type something here..."
                                               Foreground="{Binding ThemeState.InputWatermarkForegroundBrush, ElementName=Root}"
                                               FontStyle="Italic"
                                               Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Style="{StaticResource WaitPanelStyle}">
            <Border Style="{StaticResource PreviewSurfaceStyle}">
                <StackPanel>
                    <TextBlock Text="Live Preview" Style="{StaticResource PreviewCaptionStyle}"/>
                    <Border Margin="0,10,0,0"
                            Background="{Binding ThemeState.WaitForUserInputContainerBackgroundBrush, ElementName=Root}"
                            BorderBrush="{Binding ThemeState.WaitForUserInputHighlightBrush, ElementName=Root}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Waiting For User Input"
                                       Foreground="{Binding ThemeState.WaitForUserInputHighlightBrush, ElementName=Root}"
                                       FontWeight="SemiBold"/>
                            <Border Margin="0,10,0,0"
                                    Background="{Binding ThemeState.WaitForUserInputTextBoxBackgroundBrush, ElementName=Root}"
                                    BorderBrush="{Binding ThemeState.WaitForUserInputHighlightBrush, ElementName=Root}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Type y / n to continue..."
                                               Foreground="{Binding ThemeState.WaitForUserInputWatermarkForegroundBrush, ElementName=Root}"
                                               FontSize="12"
                                               FontStyle="Italic"/>
                                    <TextBlock Text="Please confirm the next step."
                                               Foreground="{Binding ThemeState.WaitForUserInputTextBoxForegroundBrush, ElementName=Root}"
                                               FontSize="12"
                                               Margin="0,8,0,0"/>
                                    <TextBlock Text="[Y] Yes    [N] No"
                                               Foreground="{Binding ThemeState.WaitForUserInputTextBoxForegroundBrush, ElementName=Root}"
                                               FontFamily="Consolas"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Style="{StaticResource ButtonsPanelStyle}">
            <Border Style="{StaticResource PreviewSurfaceStyle}">
                <StackPanel>
                    <TextBlock Text="Live Preview" Style="{StaticResource PreviewCaptionStyle}"/>
                    <Border Margin="0,10,0,0"
                            Background="{Binding ThemeState.WindowBackgroundBrush, ElementName=Root}"
                            BorderBrush="#17181A"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Default" Foreground="#A8A8A8" FontSize="11" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="State" Foreground="#A8A8A8" FontSize="11" Margin="8,0,0,8"/>

                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PreviewButtonBorderStyle}" Background="{Binding ThemeState.SendButtonBackgroundBrush, ElementName=Root}" Margin="0,0,8,8">
                                <TextBlock Text="Send" Foreground="{Binding ThemeState.SendButtonForegroundBrush, ElementName=Root}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PreviewButtonBorderStyle}" Background="{Binding ThemeState.SendButtonHoverBackgroundBrush, ElementName=Root}" Margin="8,0,0,8">
                                <TextBlock Text="Send Hover" Foreground="{Binding ThemeState.SendButtonHoverForegroundBrush, ElementName=Root}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource PreviewButtonBorderStyle}" Background="{Binding ThemeState.HistoryButtonBackgroundBrush, ElementName=Root}" Margin="0,0,8,8">
                                <TextBlock Text="History" Foreground="{Binding ThemeState.HistoryButtonForegroundBrush, ElementName=Root}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource PreviewButtonBorderStyle}" Background="{Binding ThemeState.HistoryButtonHoverBackgroundBrush, ElementName=Root}" Margin="8,0,0,8">
                                <TextBlock Text="History Hover" Foreground="{Binding ThemeState.HistoryButtonHoverForegroundBrush, ElementName=Root}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>

                            <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource PreviewButtonBorderStyle}" Background="{Binding ThemeState.DraftButtonBackgroundBrush, ElementName=Root}" Margin="0,0,8,0">
                                <TextBlock Text="Draft" Foreground="{Binding ThemeState.DraftButtonForegroundBrush, ElementName=Root}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource PreviewButtonBorderStyle}" Background="{Binding ThemeState.DraftButtonActiveBackgroundBrush, ElementName=Root}" Margin="8,0,0,0">
                                <TextBlock Text="Draft Active" Foreground="{Binding ThemeState.DraftButtonActiveForegroundBrush, ElementName=Root}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Style="{StaticResource MenusPanelStyle}">
            <Border Style="{StaticResource PreviewSurfaceStyle}">
                <StackPanel>
                    <TextBlock Text="Live Preview" Style="{StaticResource PreviewCaptionStyle}"/>
                    <Border Margin="0,10,0,0"
                            Background="{Binding ThemeState.ContextMenuBackgroundBrush, ElementName=Root}"
                            BorderBrush="{Binding ThemeState.ContextMenuBorderBrush, ElementName=Root}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Margin="0,0,0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding ThemeState.ContextMenuGutterBackgroundBrush, ElementName=Root}"/>
                                    <TextBlock Grid.Column="1" Text="Select All" Foreground="{Binding ThemeState.ContextMenuForegroundBrush, ElementName=Root}" Margin="6,5,0,5" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Ctrl+A" Foreground="{Binding ThemeState.ContextMenuShortcutForegroundBrush, ElementName=Root}" Margin="12,5,8,5" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Background="{Binding ThemeState.ContextMenuHighlightBackgroundBrush, ElementName=Root}" Margin="0,0,0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding ThemeState.ContextMenuHighlightBackgroundBrush, ElementName=Root}"/>
                                    <TextBlock Grid.Column="1" Text="Paste" Foreground="{Binding ThemeState.ContextMenuForegroundBrush, ElementName=Root}" Margin="6,5,0,5" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Ctrl+V" Foreground="{Binding ThemeState.ContextMenuShortcutForegroundBrush, ElementName=Root}" Margin="12,5,8,5" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Margin="0,0,0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding ThemeState.ContextMenuGutterBackgroundBrush, ElementName=Root}"/>
                                    <TextBlock Grid.Column="0" Text="✓" Foreground="{Binding ThemeState.ContextMenuAccentForegroundBrush, ElementName=Root}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Submit: Single Enter" Foreground="{Binding ThemeState.ContextMenuForegroundBrush, ElementName=Root}" Margin="6,5,0,5" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="3" Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{Binding ThemeState.ContextMenuGutterBackgroundBrush, ElementName=Root}"/>
                                <Border Grid.Column="1" Height="1" Background="{Binding ThemeState.ContextMenuSeparatorBrush, ElementName=Root}" Margin="8,0,12,0" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Grid.Row="4" Margin="0,0,0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding ThemeState.ContextMenuGutterBackgroundBrush, ElementName=Root}"/>
                                    <TextBlock Grid.Column="1" Text="Group Header" Foreground="{Binding ThemeState.ContextMenuGroupHeaderForegroundBrush, ElementName=Root}" FontWeight="SemiBold" Margin="6,5,0,5" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding ThemeState.ContextMenuGutterBackgroundBrush, ElementName=Root}"/>
                                    <TextBlock Grid.Column="0" Text="✓" Foreground="{Binding ThemeState.ContextMenuAccentForegroundBrush, ElementName=Root}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Enable Auto Draft Queue On Completion" Foreground="{Binding ThemeState.ContextMenuForegroundBrush, ElementName=Root}" Margin="6,5,0,5" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Margin="0,14,0,0"
                            Background="{Binding ThemeState.CommandPopupBackgroundBrush, ElementName=Root}"
                            BorderBrush="{Binding ThemeState.CommandPopupBorderBrush, ElementName=Root}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel>
                            <Border Background="{Binding ThemeState.CommandPopupHeaderBackgroundBrush, ElementName=Root}"
                                    Padding="10,7"
                                    CornerRadius="4,4,0,0">
                                <TextBlock Text="/build"
                                           Foreground="{Binding ThemeState.CommandPopupHeaderForegroundBrush, ElementName=Root}"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <StackPanel Margin="4">
                                <Border Padding="8,6" CornerRadius="3">
                                    <TextBlock Text="dotnet build src/TerminalShell/TerminalShell.csproj -c Release"
                                               Foreground="{Binding ThemeState.CommandPopupItemForegroundBrush, ElementName=Root}"
                                               TextWrapping="Wrap"/>
                                </Border>
                                <Border Padding="8,6"
                                        Background="{Binding ThemeState.CommandPopupItemHoverBackgroundBrush, ElementName=Root}"
                                        CornerRadius="3"
                                        Margin="0,4,0,0">
                                    <TextBlock Text="dotnet test src/TerminalShell.sln -c Release"
                                               Foreground="{Binding ThemeState.CommandPopupItemForegroundBrush, ElementName=Root}"
                                               TextWrapping="Wrap"/>
                                </Border>
                                <Border Padding="8,6"
                                        Background="{Binding ThemeState.CommandPopupItemSelectedBackgroundBrush, ElementName=Root}"
                                        CornerRadius="3"
                                        Margin="0,4,0,0">
                                    <TextBlock Text="dotnet publish src/TerminalShell/TerminalShell.csproj -c Release"
                                               Foreground="{Binding ThemeState.CommandPopupItemForegroundBrush, ElementName=Root}"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
