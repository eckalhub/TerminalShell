<Window x:Class="TerminalShell.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TerminalShell.Views"
        xmlns:helpers="clr-namespace:TerminalShell.Helpers"
        mc:Ignorable="d"
        Title="Color Picker"
        Width="800"
        Height="550"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ColorButtonStyle">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFA0A0A0"/>
            <Setter Property="ToolTip" Value="{Binding Converter={x:Static local:ColorHexConverter.Instance}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#FFD700"
                                                            Duration="0:0:0.05"/>
                                            <ThicknessAnimation Storyboard.TargetName="border"
                                                                Storyboard.TargetProperty="BorderThickness"
                                                                To="2"
                                                                Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <Button Content="Auto 默认色"
                    Height="30"
                    Margin="0,0,0,10"
                    Command="{Binding SetColorCommand}"
                    CommandParameter="{Binding DefaultColor}"/>

            <TextBlock Text="Theme Colors" FontWeight="Bold" Margin="0,5"/>
            <ItemsControl ItemsSource="{Binding ThemeColors}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="12"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource ColorButtonStyle}"
                                Background="{Binding Converter={x:Static local:ColorBrushConverter.Instance}}"
                                Command="{Binding DataContext.SetColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="{Binding Converter={x:Static local:ColorHexConverter.Instance}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Custom Colors" FontWeight="Bold" Margin="0,25,0,5"/>
            <ItemsControl ItemsSource="{Binding CustomColors}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource ColorButtonStyle}"
                                Background="{Binding Converter={x:Static local:ColorBrushConverter.Instance}}"
                                Command="{Binding DataContext.SetColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="{Binding Converter={x:Static local:ColorHexConverter.Instance}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <Rectangle Grid.Column="0" HorizontalAlignment="Right" Width="1" Fill="#FFE0E0E0"/>

        <Grid Grid.Column="1" Margin="15,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>

                <Canvas x:Name="SpectrumCanvas"
                        Grid.Column="0"
                        Margin="0,0,10,15"
                        MouseDown="SpectrumCanvas_MouseDown"
                        MouseMove="SpectrumCanvas_MouseMove"
                        MouseUp="Canvas_MouseUp">
                    <Canvas.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFF0000" Offset="0"/>
                            <GradientStop Color="#FFFFFF00" Offset="0.16"/>
                            <GradientStop Color="#FF00FF00" Offset="0.33"/>
                            <GradientStop Color="#FF00FFFF" Offset="0.5"/>
                            <GradientStop Color="#FF0000FF" Offset="0.66"/>
                            <GradientStop Color="#FFFF00FF" Offset="0.83"/>
                            <GradientStop Color="#FFFF0000" Offset="1"/>
                        </LinearGradientBrush>
                    </Canvas.Background>
                    <Rectangle Width="{Binding ElementName=SpectrumCanvas, Path=ActualWidth}"
                               Height="{Binding ElementName=SpectrumCanvas, Path=ActualHeight}">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="0.5"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle Width="{Binding ElementName=SpectrumCanvas, Path=ActualWidth}"
                               Height="{Binding ElementName=SpectrumCanvas, Path=ActualHeight}"
                               IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <SolidColorBrush Color="Black"
                                             Opacity="{Binding V, Converter={x:Static local:BrightnessToOpacityConverter.Instance}}"/>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Ellipse x:Name="SpectrumThumb"
                             Width="10"
                             Height="10"
                             Stroke="Black"
                             StrokeThickness="1"
                             Fill="Transparent"
                             IsHitTestVisible="False"/>
                </Canvas>

                <Canvas x:Name="BrightnessCanvas"
                        Grid.Column="1"
                        Margin="0,0,0,15"
                        Background="Transparent"
                        MouseDown="BrightnessCanvas_MouseDown"
                        MouseMove="BrightnessCanvas_MouseMove"
                        MouseUp="Canvas_MouseUp">
                    <Rectangle Width="12"
                               Height="{Binding ElementName=BrightnessCanvas, Path=ActualHeight}"
                               RadiusX="2"
                               RadiusY="2"
                               Stroke="Gray"
                               StrokeThickness="1"
                               HorizontalAlignment="Left"
                               Canvas.Left="0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="{Binding SpectrumColor}" Offset="0"/>
                                <GradientStop Color="Black" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Path x:Name="BrightnessThumb"
                          Fill="Black"
                          StrokeThickness="0"
                          IsHitTestVisible="False">
                        <Path.Data>
                            <GeometryGroup>
                                <PathGeometry Figures="M 6,0 L 0,5 L 6,10 Z"/>
                            </GeometryGroup>
                        </Path.Data>
                    </Path>
                </Canvas>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        CornerRadius="5"
                        Background="{Binding CurrentColorBrush}"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        Margin="0,0,15,0"/>

                <StackPanel Grid.Column="1">
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hue" Grid.Column="0" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="360" Value="{Binding H}" SmallChange="1" LargeChange="10" Margin="5,0">
                            <Slider.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFFF0000" Offset="0"/>
                                    <GradientStop Color="#FFFFFF00" Offset="0.16"/>
                                    <GradientStop Color="#FF00FF00" Offset="0.33"/>
                                    <GradientStop Color="#FF00FFFF" Offset="0.5"/>
                                    <GradientStop Color="#FF0000FF" Offset="0.66"/>
                                    <GradientStop Color="#FFFF00FF" Offset="0.83"/>
                                    <GradientStop Color="#FFFF0000" Offset="1"/>
                                </LinearGradientBrush>
                            </Slider.Background>
                        </Slider>
                        <TextBlock Text="{Binding H, StringFormat=N0}" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Saturation" Grid.Column="0" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding S}" SmallChange="1" LargeChange="10" Margin="5,0">
                            <Slider.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="{Binding SpectrumColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Slider.Background>
                        </Slider>
                        <TextBlock Text="{Binding S, StringFormat=N0}" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Brightness" Grid.Column="0" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding V}" SmallChange="1" LargeChange="10" Margin="5,0">
                            <Slider.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Black" Offset="0"/>
                                    <GradientStop Color="{Binding SpectrumColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Slider.Background>
                        </Slider>
                        <TextBlock Text="{Binding V, StringFormat=N0}" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="R:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding R, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="0,5"
                         helpers:InputValidationHelper.ValidationMode="Integer"
                         helpers:InputValidationHelper.MinValue="0"
                         helpers:InputValidationHelper.MaxValue="255"/>

                <TextBlock Text="G:" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding G, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="4" Margin="0,5"
                         helpers:InputValidationHelper.ValidationMode="Integer"
                         helpers:InputValidationHelper.MinValue="0"
                         helpers:InputValidationHelper.MaxValue="255"/>

                <TextBlock Text="B:" Grid.Row="0" Grid.Column="6" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding B, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="7" Margin="0,5"
                         helpers:InputValidationHelper.ValidationMode="Integer"
                         helpers:InputValidationHelper.MinValue="0"
                         helpers:InputValidationHelper.MaxValue="255"/>

                <TextBlock Text="Hex:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding Hex, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="7"
                         Margin="0,5"
                         helpers:InputValidationHelper.ValidationMode="HexColor"/>
            </Grid>

            <Grid Grid.Row="4" Margin="0,15,0,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Add to Custom Colors"
                        Height="30"
                        HorizontalAlignment="Left"
                        Width="160"
                        Command="{Binding AddCustomColorCommand}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="OK" IsDefault="True" Height="30" Width="80" Margin="0,0,10,0" Click="OkButton_Click"/>
                    <Button Content="Cancel" IsCancel="True" Height="30" Width="80"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
