<Window x:Class="TerminalShell.Views.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mwt="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero2"
        xmlns:vm="clr-namespace:TerminalShell.ViewModels"
        xmlns:models="clr-namespace:TerminalShell.Models"
        xmlns:ctrl="clr-namespace:TerminalShell.Controls"
        xmlns:conv="clr-namespace:TerminalShell.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="1300" Width="2980"
        Topmost="{Binding IsTopmost, Mode=TwoWay}"
        Background="{Binding ThemeState.WindowBackgroundBrush}">
    
    <Window.Resources>
        <conv:DynamicPercentageConverter x:Key="DynamicPercentageConverter"/>
        <conv:MaximizedSessionVisibilityConverter x:Key="MaximizedSessionVisibilityConverter"/>
        <conv:IsMaximizedSessionConverter x:Key="IsMaximizedSessionConverter"/>
        <conv:DynamicStringFormatConverter x:Key="DynamicStringFormatConverter"/>
        <conv:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>
        <conv:BooleanBrushSwitchConverter x:Key="BooleanBrushSwitchConverter"/>
        <conv:DraftQueueStateBrushConverter x:Key="DraftQueueStateBrushConverter"/>
        <conv:SelectionStateBrushConverter x:Key="SelectionStateBrushConverter"/>

        <Style x:Key="ThemedActionButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedHeaderButtonStyle" TargetType="Button" BasedOn="{StaticResource ThemedActionButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="2,0"/>
        </Style>

        <Style x:Key="ThemedMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Grid Margin="0,4,0,4"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" SharedSizeGroup="ContextMenuGutterColumn"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="ContextMenuShortcutColumn"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="ContextMenuArrowColumn"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="{Binding DataContext.ThemeState.ContextMenuGutterBackgroundBrush, Source={x:Reference RootWindow}}"/>
                            <Border Grid.Column="1"
                                    Grid.ColumnSpan="3"
                                    Height="1"
                                    Background="{Binding DataContext.ThemeState.ContextMenuSeparatorBrush, Source={x:Reference RootWindow}}"
                                    Margin="8,0,12,0"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedMenuItemStyle" TargetType="MenuItem">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MenuFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{DynamicResource {x:Static SystemFonts.MenuFontSizeKey}}"/>
            <Setter Property="Foreground" Value="{Binding DataContext.ThemeState.ContextMenuForegroundBrush, Source={x:Reference RootWindow}}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,6,20,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuItemChrome"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" SharedSizeGroup="ContextMenuGutterColumn"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ContextMenuShortcutColumn"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ContextMenuArrowColumn"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="GutterBackground"
                                        Grid.Column="0"
                                        Background="{Binding DataContext.ThemeState.ContextMenuGutterBackgroundBrush, Source={x:Reference RootWindow}}"/>

                                <TextBlock x:Name="CheckGlyph"
                                           Grid.Column="0"
                                           Text="✓"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding DataContext.ThemeState.ContextMenuAccentForegroundBrush, Source={x:Reference RootWindow}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>

                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="2"
                                           Text="{TemplateBinding InputGestureText}"
                                           Margin="12,0,8,0"
                                           Foreground="{Binding DataContext.ThemeState.ContextMenuShortcutForegroundBrush, Source={x:Reference RootWindow}}"
                                           VerticalAlignment="Center"/>

                                <TextBlock x:Name="SubmenuArrow"
                                           Grid.Column="3"
                                           Text="▶"
                                           Margin="6,0,10,0"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>

                                <Popup x:Name="SubmenuPopup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Right"
                                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="Fade">
                                    <Border Background="{Binding DataContext.ThemeState.ContextMenuBackgroundBrush, Source={x:Reference RootWindow}}"
                                            BorderBrush="{Binding DataContext.ThemeState.ContextMenuBorderBrush, Source={x:Reference RootWindow}}"
                                            BorderThickness="1"
                                            Padding="2"
                                            Grid.IsSharedSizeScope="True"
                                            SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="GutterBackground" Property="Background" Value="{Binding DataContext.ThemeState.ContextMenuHighlightBackgroundBrush, Source={x:Reference RootWindow}}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{Binding DataContext.ThemeState.ContextMenuHighlightBackgroundBrush, Source={x:Reference RootWindow}}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ThemedContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MenuFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{DynamicResource {x:Static SystemFonts.MenuFontSizeKey}}"/>
            <Setter Property="Background" Value="{Binding DataContext.ThemeState.ContextMenuBackgroundBrush, Source={x:Reference RootWindow}}"/>
            <Setter Property="Foreground" Value="{Binding DataContext.ThemeState.ContextMenuForegroundBrush, Source={x:Reference RootWindow}}"/>
            <Setter Property="BorderBrush" Value="{Binding DataContext.ThemeState.ContextMenuBorderBrush, Source={x:Reference RootWindow}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Grid.IsSharedSizeScope" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <mwt:SystemDropShadowChrome x:Name="Shdw"
                                                    SnapsToDevicePixels="True"
                                                    Color="#00FFFFFF">
                            <Border x:Name="ContextMenuBorder"
                                    Background="{TemplateBinding Panel.Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="ContextMenuScrollViewer"
                                              Margin="1,0,1,0"
                                              Grid.ColumnSpan="2"
                                              Style="{DynamicResource {ComponentResourceKey TypeInTargetAssembly={x:Type FrameworkElement}, ResourceId=MenuScrollViewer}}">
                                    <Grid RenderOptions.ClearTypeHint="Enabled">
                                        <Canvas Width="0"
                                                Height="0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top">
                                            <Rectangle x:Name="OpaqueRect"
                                                       Fill="{x:Null}"
                                                       Width="Auto"
                                                       Height="Auto"/>
                                        </Canvas>
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        Margin="{TemplateBinding Padding}"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </mwt:SystemDropShadowChrome>
                        <ControlTemplate.Triggers>
                            <Trigger Property="ContextMenuService.HasDropShadow" Value="True">
                                <Setter TargetName="Shdw" Property="Margin" Value="0,0,5,5"/>
                                <Setter TargetName="Shdw" Property="mwt:SystemDropShadowChrome.Color" Value="#71000000"/>
                            </Trigger>
                            <Trigger Property="ScrollViewer.CanContentScroll" SourceName="ContextMenuScrollViewer" Value="False">
                                <Setter TargetName="OpaqueRect" Property="Canvas.Top" Value="{Binding VerticalOffset, ElementName=ContextMenuScrollViewer}"/>
                                <Setter TargetName="OpaqueRect" Property="Canvas.Left" Value="{Binding HorizontalOffset, ElementName=ContextMenuScrollViewer}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for the Output TextBox -->
        <Style x:Key="TerminalOutputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0C0C0C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Style for Input TextBox -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <!-- Auto Height for Expansion -->
            <Setter Property="Height" Value="Auto"/>
            <!-- Bind MinHeight to ViewModel -->
            <!-- Note: DataContext here is TerminalSession, we need to find MainViewModel. -->
            <!-- Assuming MainViewModel is the DataContext of the Window/ItemsControl -->
            <Setter Property="MinHeight" Value="{Binding DataContext.InputMinHeight, RelativeSource={RelativeSource AncestorType=Window}}"/>
            
            <!-- MaxHeight Binding moved to TextBox instance via ElementName -->

            <Setter Property="FontSize" Value="{Binding DataContext.InputFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>

            <Setter Property="FontFamily" Value="{Binding DataContext.ParsedInputFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <!-- Add Bottom Padding for 2 lines buffer -->
            <!-- 2 lines * approx 1.2 line height usually. For 14px font, line height ~17px. 2 lines ~34px. -->
            <!-- Ideally this is dynamic based on FontSize, but fixed padding is a good start. -->
            <Setter Property="Padding" Value="{Binding DataContext.InputTextBoxPadding, RelativeSource={RelativeSource AncestorType=Window}}"/> 
            
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            
            <!-- ScrollViewer auto visibility -->
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- DataTemplate for each Terminal Session -->
        <DataTemplate DataType="{x:Type models:TerminalSession}">
            <Border x:Name="SessionContainer"
                    BorderBrush="{Binding DataContext.ThemeState.SessionBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                    BorderThickness="1"
                    Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Output Log -->
                        <RowDefinition Height="Auto"/> <!-- Input Area -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="{Binding DataContext.ThemeState.SessionHeaderBackgroundBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                            Padding="5"
                            ContextMenuOpening="SessionHeader_ContextMenuOpening"
                            PreviewMouseRightButtonUp="SessionHeader_PreviewMouseRightButtonUp">
                        <Border.ContextMenu>
                            <ContextMenu Style="{StaticResource ThemedContextMenuStyle}"
                                         Opened="HeaderContextMenu_Opened"
                                         Closed="HeaderContextMenu_Closed">
                                <MenuItem Header="Settings" 
                                          Style="{StaticResource ThemedMenuItemStyle}"
                                          Command="{Binding OpenSettingsCommand}"/>
                                <MenuItem Header="Show Terminal" 
                                          Style="{StaticResource ThemedMenuItemStyle}"
                                          ItemsSource="{Binding GroupedMenuTerminals}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="MenuItem" BasedOn="{StaticResource ThemedMenuItemStyle}">
                                            <Setter Property="Header" Value="{Binding HeaderText}" />
                                            <Setter Property="Command" Value="{Binding Command}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="Foreground" Value="{Binding DataContext.ThemeState.ContextMenuGroupHeaderForegroundBrush, Source={x:Reference RootWindow}}" />
                                                    <Setter Property="Margin" Value="0,5,0,2" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsHeader}" Value="False">
                                                    <Setter Property="Margin" Value="15,0,0,0" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                                <MenuItem Header="Restart This Terminal"
                                          Style="{StaticResource ThemedMenuItemStyle}"
                                          Command="{Binding ReloadTerminalCommand}"/>
                                <MenuItem Header="{Binding OpenWorkingDirectoryMenuText}"
                                          Style="{StaticResource ThemedMenuItemStyle}"
                                          Command="{Binding OpenWorkingDirectoryCommand}"/>
                                <MenuItem Header="Hide" 
                                          Style="{StaticResource ThemedMenuItemStyle}"
                                          Command="{Binding HideCommand}"/>
                                <Separator Style="{StaticResource ThemedMenuSeparatorStyle}"/>
                                <MenuItem Header="Toggle Fullscreen" 
                                          Style="{StaticResource ThemedMenuItemStyle}"
                                          Command="{Binding ToggleFullScreenCommand}"/>
                                <Separator Style="{StaticResource ThemedMenuSeparatorStyle}"/>
                                <MenuItem Header="Always on Top" 
                                          Style="{StaticResource ThemedMenuItemStyle}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsTopmost, Mode=TwoWay}"/>
                                <MenuItem Header="Allow sound reminders after tasks are completed"
                                          Style="{StaticResource ThemedMenuItemStyle}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsAllTaskAlertsEnabled, Mode=TwoWay}"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        
                        <!-- Header Input Bindings for Double Click -->
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick"
                                          Command="{Binding DataContext.ToggleFullScreenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>

                        <Grid>
                             <Grid.ColumnDefinitions>
                                 <ColumnDefinition Width="*"/>
                                 <ColumnDefinition Width="Auto"/>
                             </Grid.ColumnDefinitions>
                             
                             <TextBlock Grid.Column="0"
                                        Text="{Binding Title}"
                                        Foreground="{Binding DataContext.ThemeState.SessionHeaderForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                        FontWeight="Bold"
                                        VerticalAlignment="Center"/>
                             
                             <!-- Maximize/Restore Icons -->
                             <StackPanel Grid.Column="1" Orientation="Horizontal">
                                 <!-- Maximize Icon (Show if NOT Maximized) -->
                                 <Button Content="[ ]" 
                                         Background="Transparent"
                                         Foreground="{Binding DataContext.ThemeState.SessionHeaderForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                         BorderThickness="0"
                                         Command="{Binding DataContext.ToggleFullScreenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                         CommandParameter="{Binding}"
                                         ToolTip="Maximize">
                                     <Button.Style>
                                         <Style TargetType="Button" BasedOn="{StaticResource ThemedHeaderButtonStyle}">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding DataContext.MaximizedSession, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Null}">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </Button.Style>
                                 </Button>
                                 
                                 <!-- Restore Icon (Show if Maximized) -->
                                 <Button Content="&lt;-" 
                                         Background="Transparent"
                                         Foreground="{Binding DataContext.ThemeState.SessionHeaderForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                         BorderThickness="0"
                                         Command="{Binding DataContext.ToggleFullScreenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                         CommandParameter="{Binding}"
                                         ToolTip="Restore">
                                     <Button.Style>
                                         <Style TargetType="Button" BasedOn="{StaticResource ThemedHeaderButtonStyle}">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Value="True">
                                                     <DataTrigger.Binding>
                                                         <MultiBinding Converter="{StaticResource IsMaximizedSessionConverter}">
                                                             <Binding />
                                                             <Binding Path="DataContext.MaximizedSession" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                         </MultiBinding>
                                                     </DataTrigger.Binding>
                                                     <!-- Use IsMaximizedSessionConverter which returns bool -->
                                                      <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </Button.Style>
                                 </Button>
                             </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Output Log (Native Host) -->
                    <ctrl:ConsoleHost Grid.Row="1" 
                                      AppProcess="{Binding AppProcess}"/>

                    <!-- Input Area -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="6"/>  <!-- Drag-to-Resize Handle Row -->
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Drag Resize Handle: hover to highlight, drag to change InputMinHeight -->
                        <Border Grid.Row="0" Tag="ResizeHandle" Cursor="SizeNS">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{Binding DataContext.ThemeState.ResizeHandleHoverBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <Border Grid.Row="1"
                                Padding="{Binding DataContext.InputContainerPadding, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Border.Background>
                            <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                <Binding Path="IsWaitingForUserInput"/>
                                <Binding Path="DataContext.ThemeState.InputContainerBackgroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                <Binding Path="DataContext.ThemeState.WaitForUserInputContainerBackgroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            </MultiBinding>
                        </Border.Background>
                        <Border.BorderBrush>
                            <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                <Binding Path="IsWaitingForUserInput"/>
                                <Binding Path="DataContext.TransparentBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                <Binding Path="DataContext.ThemeState.WaitForUserInputHighlightBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            </MultiBinding>
                        </Border.BorderBrush>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWaitingForUserInput}" Value="True">
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Input Box: Pre-edited content (TwoWay) -->
                            <TextBox x:Name="InputTextBox"
                                     Grid.Column="0" 
                                     FontSize="{Binding DataContext.InputFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                     FontFamily="{Binding DataContext.ParsedInputFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                     Text="{Binding InputBuffer, UpdateSourceTrigger=PropertyChanged}"
                                     Loaded="InputBox_Loaded"
                                     PreviewKeyDown="InputBox_KeyDown"
                                     PreviewTextInput="InputBox_PreviewTextInput"
                                     SizeChanged="InputBox_SizeChanged"
                                     TextChanged="InputBox_TextChanged"
                                     Unloaded="InputBox_Unloaded"
                                     Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                <TextBox.Background>
                                    <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                        <Binding Path="IsWaitingForUserInput"/>
                                        <Binding Path="DataContext.ThemeState.InputTextBoxBackgroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="DataContext.ThemeState.WaitForUserInputTextBoxBackgroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </TextBox.Background>
                                <TextBox.BorderBrush>
                                    <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                        <Binding Path="IsWaitingForUserInput"/>
                                        <Binding Path="DataContext.ThemeState.InputTextBoxBorderBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="DataContext.ThemeState.WaitForUserInputHighlightBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </TextBox.BorderBrush>
                                <TextBox.Foreground>
                                    <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                        <Binding Path="IsWaitingForUserInput"/>
                                        <Binding Path="DataContext.ThemeState.InputTextBoxForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="DataContext.ThemeState.WaitForUserInputTextBoxForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </TextBox.Foreground>
                                <TextBox.CaretBrush>
                                    <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                        <Binding Path="IsWaitingForUserInput"/>
                                        <Binding Path="DataContext.ThemeState.InputTextBoxForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="DataContext.ThemeState.WaitForUserInputTextBoxForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </TextBox.CaretBrush>
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource InputBoxStyle}"/>
                                </TextBox.Style>
                                <TextBox.ContextMenu>
                                    <ContextMenu Style="{StaticResource ThemedContextMenuStyle}">
                                        <MenuItem Command="ApplicationCommands.SelectAll" Header="Select All" InputGestureText="Ctrl+A" Style="{StaticResource ThemedMenuItemStyle}" />
                                        <MenuItem Command="ApplicationCommands.Copy" Header="Copy" InputGestureText="Ctrl+C" Style="{StaticResource ThemedMenuItemStyle}" />
                                        <MenuItem Command="ApplicationCommands.Cut" Header="Cut" InputGestureText="Ctrl+X" Style="{StaticResource ThemedMenuItemStyle}" />
                                        <MenuItem Command="ApplicationCommands.Paste" Header="Paste" InputGestureText="Ctrl+V" Style="{StaticResource ThemedMenuItemStyle}" />
                                        <Separator Style="{StaticResource ThemedMenuSeparatorStyle}"/>
                                        <MenuItem Header="Clear" Style="{StaticResource ThemedMenuItemStyle}" Command="{Binding ClearInputCommand}" />
                                        <Separator Style="{StaticResource ThemedMenuSeparatorStyle}"/>
                                        <MenuItem Header="Submit: Double Enter" Style="{StaticResource ThemedMenuItemStyle}" IsCheckable="True" IsChecked="{Binding PlacementTarget.Tag.IsDoubleEnterMode, Mode=OneWay, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Command="{Binding PlacementTarget.Tag.SetSubmitModeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="DoubleEnter" />
                                        <MenuItem Header="Submit: Single Enter" Style="{StaticResource ThemedMenuItemStyle}" IsCheckable="True" IsChecked="{Binding PlacementTarget.Tag.IsSingleEnterMode, Mode=OneWay, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Command="{Binding PlacementTarget.Tag.SetSubmitModeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="SingleEnter" />
                                        <Separator Style="{StaticResource ThemedMenuSeparatorStyle}"/>
                                        <MenuItem Header="Paste Output: Markdown" Style="{StaticResource ThemedMenuItemStyle}" IsCheckable="True" IsChecked="{Binding PlacementTarget.Tag.IsMarkdownOutputMode, Mode=OneWay, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Command="{Binding PlacementTarget.Tag.SetClipboardOutputFormatCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="markdown" />
                                        <MenuItem Header="Paste Output: Raw Text" Style="{StaticResource ThemedMenuItemStyle}" IsCheckable="True" IsChecked="{Binding PlacementTarget.Tag.IsTextOutputMode, Mode=OneWay, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Command="{Binding PlacementTarget.Tag.SetClipboardOutputFormatCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="text" />
                                        <Separator Style="{StaticResource ThemedMenuSeparatorStyle}"/>
                                        <MenuItem Header="Settings"
                                                  Style="{StaticResource ThemedMenuItemStyle}"
                                                  Command="{Binding PlacementTarget.Tag.OpenSettingsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Separator Style="{StaticResource ThemedMenuSeparatorStyle}"/>
                                        <MenuItem Header="Allow sound reminders after tasks are completed"
                                                  Style="{StaticResource ThemedMenuItemStyle}"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding PlacementTarget.Tag.IsAllTaskAlertsEnabled, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Separator Style="{StaticResource ThemedMenuSeparatorStyle}"/>
                                        <MenuItem Header="Read Terminal Context" Style="{StaticResource ThemedMenuItemStyle}" Command="{Binding ReadTerminalContentCommand}" />
                                        <MenuItem Header="Save The current text content to File ..." Style="{StaticResource ThemedMenuItemStyle}" Command="{Binding SaveInputToFileCommand}" />
                                        <Separator Style="{StaticResource ThemedMenuSeparatorStyle}"/>
                                        <MenuItem Header="Enable Auto Draft Queue On Completion"
                                                  Style="{StaticResource ThemedMenuItemStyle}"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding IsAutoDraftQueueEnabled, Mode=OneWay}"
                                                  Command="{Binding PlacementTarget.Tag.ToggleAutoDraftQueueForSessionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Save To Draft" Style="{StaticResource ThemedMenuItemStyle}" Command="{Binding SaveDraftCommand}" />
                                    </ContextMenu>
                                </TextBox.ContextMenu>
                                <TextBox.MaxHeight>
                                    <MultiBinding Converter="{StaticResource DynamicPercentageConverter}">
                                        <Binding Path="ActualHeight" ElementName="SessionContainer"/>
                                        <Binding Path="DataContext.InputMaxHeightPercent" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </TextBox.MaxHeight>
                                <TextBox.InputBindings>
                                    <!-- KeyBinding Removed -->
                                </TextBox.InputBindings>
                            </TextBox>

                            <!-- IntelliSense Command Popup -->
                            <Popup IsOpen="{Binding IsCommandPopupOpen}" 
                                   PlacementTarget="{Binding ElementName=InputTextBox}"
                                   Placement="Top" StaysOpen="False"
                                   Opened="CommandPopup_Opened"
                                   AllowsTransparency="True" PopupAnimation="Slide">
                                <Border Background="{Binding DataContext.ThemeState.CommandPopupBackgroundBrush, Source={x:Reference RootWindow}}"
                                        BorderBrush="{Binding DataContext.ThemeState.CommandPopupBorderBrush, Source={x:Reference RootWindow}}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Width="{Binding PlacementTarget.ActualWidth, RelativeSource={RelativeSource AncestorType=Popup}}"
                                        MinWidth="{Binding PlacementTarget.ActualWidth, RelativeSource={RelativeSource AncestorType=Popup}}"
                                        MaxWidth="{Binding PlacementTarget.ActualWidth, RelativeSource={RelativeSource AncestorType=Popup}}"
                                        MaxHeight="{Binding CommandPopupMaxHeight}" Margin="0,0,0,5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                Background="{Binding DataContext.ThemeState.CommandPopupHeaderBackgroundBrush, Source={x:Reference RootWindow}}"
                                                BorderBrush="{Binding DataContext.ThemeState.CommandPopupBorderBrush, Source={x:Reference RootWindow}}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,5"
                                                Visibility="{Binding CommandPopupHeaderVisibility}">
                                            <TextBlock Text="{Binding CommandPopupHeaderText}"
                                                       Foreground="{Binding DataContext.ThemeState.CommandPopupHeaderForegroundBrush, Source={x:Reference RootWindow}}"
                                                       FontSize="12"/>
                                        </Border>
                                        <ListBox Grid.Row="1"
                                                 ItemsSource="{Binding FilteredCommands}"
                                                 DisplayMemberPath="DisplayText"
                                                 SelectedIndex="{Binding SelectedCommandIndex, Mode=TwoWay}"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{Binding DataContext.ThemeState.CommandPopupItemForegroundBrush, Source={x:Reference RootWindow}}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 MouseLeftButtonUp="CommandPopup_MouseLeftButtonUp">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}">
                                                                    <Border.Background>
                                                                        <MultiBinding Converter="{StaticResource SelectionStateBrushConverter}">
                                                                            <Binding Path="IsSelected" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                                            <Binding Path="IsMouseOver" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                                            <Binding Path="DataContext.TransparentBrush" Source="{x:Reference RootWindow}"/>
                                                                            <Binding Path="DataContext.ThemeState.CommandPopupItemHoverBackgroundBrush" Source="{x:Reference RootWindow}"/>
                                                                            <Binding Path="DataContext.ThemeState.CommandPopupItemSelectedBackgroundBrush" Source="{x:Reference RootWindow}"/>
                                                                        </MultiBinding>
                                                                    </Border.Background>
                                                                    <ContentPresenter />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Popup>

                            <!-- Input Box Watermark (MUST be after TextBox for z-order) -->
                            <TextBlock Grid.Column="0"
                                       FontSize="{Binding DataContext.InputFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       VerticalAlignment="Top" 
                                       Margin="{Binding DataContext.InputWatermarkMargin, RelativeSource={RelativeSource AncestorType=Window}}" 
                                       IsHitTestVisible="False">
                                <TextBlock.Foreground>
                                    <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                        <Binding Path="IsWaitingForUserInput"/>
                                        <Binding Path="DataContext.ThemeState.InputWatermarkForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="DataContext.ThemeState.WaitForUserInputWatermarkForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </TextBlock.Foreground>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource DynamicStringFormatConverter}">
                                        <Binding Path="DataContext.InputWatermarkFormat" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Name"/>
                                        <Binding Path="TerminalVoiceName"/>
                                        <Binding Path="DataContext.InputWatermarkStatusSuffix" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputBuffer}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding InputBuffer}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ItemsControl Grid.Column="0"
                                          ItemsSource="{Binding InputDrafts}"
                                          Visibility="{Binding DraftOverlayVisibility}"
                                          VerticalAlignment="Bottom"
                                          Margin="6,0,6,6"
                                          Panel.ZIndex="2">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"
                                                     Columns="{Binding DraftButtonColumnCount}"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.LoadDraftCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                Style="{StaticResource ThemedActionButtonStyle}"
                                                Height="21"
                                                Margin="0,0,4,0"
                                                Padding="6,0"
                                                BorderThickness="0"
                                                ToolTip="{Binding Text}">
                                            <Button.Background>
                                                <MultiBinding Converter="{StaticResource DraftQueueStateBrushConverter}">
                                                    <Binding Path="DataContext.IsAutoDraftQueueWaitingForUserInput" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                    <Binding Path="DataContext.IsAutoDraftQueueActive" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                    <Binding Path="DataContext.ThemeState.DraftButtonBackgroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    <Binding Path="DataContext.ThemeState.DraftButtonActiveBackgroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    <Binding Path="DataContext.ThemeState.WaitForUserInputHighlightBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </Button.Background>
                                            <Button.Foreground>
                                                <MultiBinding Converter="{StaticResource DraftQueueStateBrushConverter}">
                                                    <Binding Path="DataContext.IsAutoDraftQueueWaitingForUserInput" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                    <Binding Path="DataContext.IsAutoDraftQueueActive" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                    <Binding Path="DataContext.ThemeState.DraftButtonForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    <Binding Path="DataContext.ThemeState.DraftButtonActiveForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    <Binding Path="DataContext.ThemeState.DraftButtonForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </Button.Foreground>
                                            <Button.ContextMenu>
                                                <ContextMenu Style="{StaticResource ThemedContextMenuStyle}">
                                                    <MenuItem Header="Move Left"
                                                              Style="{StaticResource ThemedMenuItemStyle}"
                                                              Command="{Binding PlacementTarget.Tag.MoveDraftLeftCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    <MenuItem Header="Move Right"
                                                              Style="{StaticResource ThemedMenuItemStyle}"
                                                              Command="{Binding PlacementTarget.Tag.MoveDraftRightCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    <Separator Style="{StaticResource ThemedMenuSeparatorStyle}"/>
                                                    <MenuItem Header="Delete Draft"
                                                              Style="{StaticResource ThemedMenuItemStyle}"
                                                              Command="{Binding PlacementTarget.Tag.DeleteDraftCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <TextBlock Text="{Binding PreviewText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Send & History Buttons -->
                            <Grid Grid.Column="1" Margin="5,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="{Binding DataContext.InputButtonGapHeight, ElementName=RootWindow, Converter={StaticResource DoubleToGridLengthConverter}}"/>
                                    <RowDefinition Height="{Binding DataContext.HistoryButtonHeight, ElementName=RootWindow, Converter={StaticResource DoubleToGridLengthConverter}}"/>
                                </Grid.RowDefinitions>
                                <!-- Send Button -->
                                <Button Grid.Row="0"
                                        Content="Send" 
                                        Click="SendButton_Click"
                                        Style="{StaticResource ThemedActionButtonStyle}"
                                        Padding="10,2"
                                        BorderThickness="0">
                                    <Button.Background>
                                        <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                            <Binding Path="IsMouseOver" RelativeSource="{RelativeSource Self}"/>
                                            <Binding Path="DataContext.ThemeState.SendButtonBackgroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="DataContext.ThemeState.SendButtonHoverBackgroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </Button.Background>
                                    <Button.Foreground>
                                        <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                            <Binding Path="IsMouseOver" RelativeSource="{RelativeSource Self}"/>
                                            <Binding Path="DataContext.ThemeState.SendButtonForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="DataContext.ThemeState.SendButtonHoverForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </Button.Foreground>
                                </Button>
                                <!-- History Button -->
                                <Button Grid.Row="2"
                                        Content="History" 
                                        Click="HistoryButton_Click"
                                        Style="{StaticResource ThemedActionButtonStyle}"
                                        Height="{Binding DataContext.HistoryButtonHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Visibility="{Binding DataContext.HistoryButtonVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Padding="10,2"
                                        BorderThickness="0">
                                    <Button.Background>
                                        <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                            <Binding Path="IsMouseOver" RelativeSource="{RelativeSource Self}"/>
                                            <Binding Path="DataContext.ThemeState.HistoryButtonBackgroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="DataContext.ThemeState.HistoryButtonHoverBackgroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </Button.Background>
                                    <Button.Foreground>
                                        <MultiBinding Converter="{StaticResource BooleanBrushSwitchConverter}">
                                            <Binding Path="IsMouseOver" RelativeSource="{RelativeSource Self}"/>
                                            <Binding Path="DataContext.ThemeState.HistoryButtonForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="DataContext.ThemeState.HistoryButtonHoverForegroundBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </Button.Foreground>
                                </Button>
                            </Grid>
                        </Grid>
                        </Border>
                    </Grid>  <!-- End Input Area Grid -->
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{Binding ThemeState.WindowBackgroundBrush}">
        <!-- Main Layout: 2x2 Grid via ItemsControl -->
        <ItemsControl ItemsSource="{Binding Sessions}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="{Binding EffectiveGridRows}"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Visibility">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource MaximizedSessionVisibilityConverter}">
                                <Binding /> <!-- Session -->
                                <Binding Path="DataContext.MaximizedSession" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ItemsControl.ItemContainerStyle>
        </ItemsControl>

    </Grid>
</Window>

