<Window x:Class="TerminalShell.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TerminalShell.ViewModels"
        xmlns:models="clr-namespace:TerminalShell.Models"
        xmlns:ctrl="clr-namespace:TerminalShell.Controls"
        xmlns:conv="clr-namespace:TerminalShell.Converters"
        xmlns:helpers="clr-namespace:TerminalShell.Helpers"
        mc:Ignorable="d"
        Title="Settings" 
        Height="{Binding WindowHeight, Mode=TwoWay, FallbackValue=1300}" 
        Width="{Binding WindowWidth, Mode=TwoWay, FallbackValue=1800}"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter" />
        
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <EventSetter Event="PreviewKeyDown" Handler="GlobalTextBox_PreviewKeyDown"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>

        <Style x:Key="FluentColorPreviewButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="点击选择颜色"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ColorSwatch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="2"
                                SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ColorSwatch" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ColorSwatch" Property="Opacity" Value="0.72"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ColorSwatch" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThemeColorHexTextBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="CaretBrush" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#8F8F8F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,0,6,0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <EventSetter Event="PreviewKeyDown" Handler="GlobalTextBox_PreviewKeyDown"/>
        </Style>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="InlineActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Dark ComboBox Style -->
        <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#3E3E42" BorderBrush="#555555" BorderThickness="1" CornerRadius="2"/>
                <Border Grid.Column="0" Background="#3E3E42" BorderBrush="Transparent" BorderThickness="0" CornerRadius="2,0,0,2" Margin="1"/>
                <Path x:Name="Arrow" Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>
        
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,5,0,25"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource DarkComboBoxToggleButton}"
                                          Focusable="False" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#3E3E42" BorderBrush="#555555" BorderThickness="1"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Padding" Value="5,3"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding NavWidth, Mode=TwoWay, Converter={StaticResource DoubleToGridLengthConverter}, FallbackValue=250}" MinWidth="150" MaxWidth="500"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Navigation List -->
        <Border Grid.RowSpan="2" Grid.Column="0" BorderBrush="#3E3E42" BorderThickness="0,0,0,0" Background="#252526">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0" ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedItem}"
                         Background="Transparent" BorderThickness="0" Foreground="White" Padding="0,10,0,0"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="ListBox_PreviewMouseMove"
                         Drop="ListBox_Drop"
                         DragOver="ListBox_DragOver"
                         DragLeave="ListBox_DragLeave">
                    <ListBox.Resources>
                        <DataTemplate DataType="{x:Type vm:GlobalSettingsViewModel}">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:CustomCommandsViewModel}">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ThemesViewModel}">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Border Height="1" Background="#3E3E42" Margin="5,8,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                        <!-- Group Header DataTemplate (Replaces CollectionViewSource Headers) -->
                        <DataTemplate DataType="{x:Type vm:GroupHeaderViewModel}">
                            <ToggleButton x:Name="HeaderBtn" IsChecked="{Binding IsExpanded}" 
                                          Command="{Binding DataContext.ToggleGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"
                                          BorderThickness="0" Background="Transparent" Cursor="Hand" Padding="0" Margin="-10,5,0,5"
                                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="{TemplateBinding Background}">
                                            <StackPanel x:Name="HeaderContent" Orientation="Horizontal" Background="Transparent">
                                                <Path x:Name="Chevron" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#A0A0A0" VerticalAlignment="Center" Margin="10,0,0,0" RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="-90"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                                <!-- Elegant Folder Icon using Vector Path -->
                                                <Path Data="M10,4H4A2,2 0 0 0 2,6V18A2,2 0 0 0 4,20H20A2,2 0 0 0 22,18V8A2,2 0 0 0 20,6H12L10,4Z" 
                                                      Fill="#E5C07B" Stretch="Uniform" Width="14" Height="12" Margin="5,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding GroupName}" Foreground="#E0E0E0" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                 <Setter TargetName="Chevron" Property="RenderTransform">
                                                      <Setter.Value>
                                                          <RotateTransform Angle="0"/>
                                                      </Setter.Value>
                                                 </Setter>
                                            </Trigger>
                                            <Trigger SourceName="HeaderContent" Property="IsMouseOver" Value="True">
                                                 <Setter Property="Background" Value="#2D2D30"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type models:TerminalConfig}">
                            <Grid Background="Transparent" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="20,0,0,0"/>
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Clone" Command="{Binding PlacementTarget.Tag.CloneCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                        <MenuItem Header="Delete" Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                            </Grid>
                        </DataTemplate>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="ctrl:DropInsertionState.Placement" Value="{x:Static ctrl:DropInsertionPlacement.None}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Grid Background="Transparent" SnapsToDevicePixels="True">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border x:Name="InsertionGapTop" Grid.Row="0" Height="0" Background="Transparent"/>
                                            <Grid x:Name="ItemChrome" Grid.Row="1" Background="{TemplateBinding Background}" MinHeight="35">
                                                <Border x:Name="SelectionBar" Width="3" HorizontalAlignment="Left" Background="#FFD700" Visibility="Collapsed" Margin="15,0,0,0"/>
                                                <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </Grid>
                                            <Border x:Name="InsertionGapBottom" Grid.Row="2" Height="0" Background="Transparent"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding ShowInMainWindow, FallbackValue=False}" Value="True">
                                                 <Setter TargetName="SelectionBar" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#3E3E42"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2D2D30"/>
                                            </Trigger>
                                            <Trigger Property="ctrl:DropInsertionState.Placement" Value="{x:Static ctrl:DropInsertionPlacement.Before}">
                                                <Setter TargetName="InsertionGapTop" Property="Height" Value="6"/>
                                            </Trigger>
                                            <Trigger Property="ctrl:DropInsertionState.Placement" Value="{x:Static ctrl:DropInsertionPlacement.After}">
                                                <Setter TargetName="InsertionGapBottom" Property="Height" Value="6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVisible, FallbackValue=True}" Value="False">
                                     <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Action Buttons: Bottom Left -->
                <Grid Grid.Row="1" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Add Folder" Command="{Binding AddFolderCommand}"
                            Margin="0,0,5,0" Padding="10,5" Background="#3E3E42" Foreground="White" BorderThickness="0" ToolTip="Create a new virtual directory"/>
                    <Button Grid.Column="1" Content="Add Terminal" Command="{Binding AddTerminalCommand}"
                            Margin="5,0,0,0" Padding="10,5" Background="#007ACC" Foreground="White" BorderThickness="0" ToolTip="Create a terminal in the root area"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Draggable Splitter -->
        <GridSplitter Grid.RowSpan="2" Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="#3E3E42" Cursor="SizeWE" Focusable="False"/>

        <!-- Right: Detail Editor (DataTemplates) -->
        <Border Grid.Row="0" Grid.Column="2" Padding="20,20,20,10">
            <ContentControl Content="{Binding SelectedItem}">
                <ContentControl.Resources>
                        
                        <!-- Template: Custom Commands Settings -->
                        <DataTemplate DataType="{x:Type vm:CustomCommandsViewModel}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid Margin="0,0,15,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Custom Commands" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="(Use '/' for global search, or press F1-F12 to open block categories in the terminal input box)" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Bottom" Margin="10,0,0,2"/>
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Margin="0,0,0,10"
                                           Foreground="#A0A0A0"
                                           TextWrapping="Wrap"
                                           Text="Category block syntax: [F3] ... [/F3]. Each non-empty line inside the block becomes one command. Commands outside blocks stay in the global '/' search."/>

                                <WrapPanel Grid.Row="2"
                                           Orientation="Horizontal"
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,8">
                                    <Button Content="[return]"
                                            Tag="[return]"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"
                                            ToolTip="Insert [return] at the current caret position"/>
                                    <Button Content="[F1]"
                                            Tag="F1"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F2]"
                                            Tag="F2"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F3]"
                                            Tag="F3"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F4]"
                                            Tag="F4"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F5]"
                                            Tag="F5"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F6]"
                                            Tag="F6"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F7]"
                                            Tag="F7"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F8]"
                                            Tag="F8"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F9]"
                                            Tag="F9"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F10]"
                                            Tag="F10"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F11]"
                                            Tag="F11"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                    <Button Content="[F12]"
                                            Tag="F12"
                                            Click="InsertCustomCommandMacro_Click"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                </WrapPanel>
                                
                                <TextBox Grid.Row="3" 
                                         x:Name="CustomCommandsTextBox"
                                         Text="{Binding CustomCommandsString, UpdateSourceTrigger=PropertyChanged}" 
                                         AcceptsReturn="True" 
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" 
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="14"
                                         Margin="0,0,0,10" Padding="10"/>

                                <Grid Grid.Row="4" Margin="0,0,0,80">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Max Display Length (Truncates with...): " VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding CustomCommandMaxDisplayLength, UpdateSourceTrigger=PropertyChanged}" Margin="0" Width="200" HorizontalAlignment="Left"/>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type vm:ThemesViewModel}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,0,15,0">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="themes" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="Reset default color for All"
                                            Command="{Binding ResetAllToDefaultsCommand}"
                                            Style="{StaticResource InlineActionButtonStyle}"
                                            Margin="12,0,0,0"
                                            Padding="12,6"
                                            ToolTip="Restore every main-window theme color to its built-in default."/>
                                </Grid>
                                <TextBlock Text="Customize colors used by the main window only. Settings and auxiliary windows keep their standard appearance. Changes preview instantly on the right inside this page before save."
                                           Style="{StaticResource HintTextStyle}"
                                           Margin="0,0,0,18"/>
                                <ItemsControl ItemsSource="{Binding Groups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SectionBorderStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,28,0">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" Foreground="#FFD700" Margin="0,0,0,10"/>
                                                        <ItemsControl ItemsSource="{Binding Items}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,0,0,8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="230"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0" Text="{Binding Label}" ToolTip="{Binding ToolTip}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <TextBox Style="{StaticResource ThemeColorHexTextBoxStyle}"
                                                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                                     ToolTip="{Binding ToolTip}"
                                                                                     helpers:InputValidationHelper.ValidationMode="HexColor"/>
                                                                            <Button Style="{StaticResource FluentColorPreviewButtonStyle}"
                                                                                    Background="{Binding PreviewBrush}"
                                                                                    ToolTip="{Binding PreviewToolTip}"
                                                                                    Click="ThemeColorPreviewButton_Click"
                                                                                    Margin="8,0,0,0"
                                                                                    VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <ctrl:ThemeGroupPreviewControl Grid.Column="1"
                                                                                   PreviewKind="{Binding PreviewKind}"
                                                                                   ThemeState="{Binding PreviewThemeState}"
                                                                                   HorizontalAlignment="Right"
                                                                                   VerticalAlignment="Top"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DataTemplate>
                        <!-- Directory Settings -->
                    <DataTemplate DataType="{x:Type vm:GroupHeaderViewModel}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="20" Background="Transparent" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                <StackPanel>
                                    <TextBlock Text="Directory Settings" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                                    <!-- Directory Name -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Directory Name" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding GroupName, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                    </Grid>
                                    
                                    <TextBlock Text="Quick Tip: Drag and drop terminals on the left navigation bar to organize your directories."
                                               Foreground="#808080" FontStyle="Italic" TextWrapping="Wrap" Margin="0,10,0,20"/>
                                    
                                    <!-- Explicit Delete Folder Button -->
                                    <Button Content="Delete"
                                            Command="{Binding Tag.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=Grid}}"
                                            CommandParameter="{Binding}"
                                            Foreground="#FF4D4D" Background="Transparent" BorderBrush="#FF4D4D" BorderThickness="1"
                                            Padding="40,10" HorizontalAlignment="Left" Width="200" 
                                            FontWeight="Bold" FontSize="14" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </DataTemplate>

                        <!-- Template: Global Settings -->
                        <DataTemplate DataType="{x:Type vm:GlobalSettingsViewModel}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="Global Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Grid Rows" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableGridRows}" SelectedItem="{Binding GridRows}" Margin="0"/>
                                    <TextBlock Grid.Column="3" Text="Input Font Settings" VerticalAlignment="Center" ToolTip="Font Size and Font Family used for the terminal input box"/>
                                    <Grid Grid.Column="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding InputFontSize, UpdateSourceTrigger=PropertyChanged}" Margin="0" TextAlignment="Center"/>
                                        <ComboBox Grid.Column="2" 
                                                  ItemsSource="{Binding AvailableFonts}" 
                                                  SelectedValuePath="Source"
                                                  SelectedValue="{Binding InputFontFamily, UpdateSourceTrigger=PropertyChanged}"
                                                  Margin="0">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Source}" FontFamily="{Binding}" ToolTip="{Binding Source}" FontSize="14"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Input Min Height (21-500 px)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding InputMinHeight, UpdateSourceTrigger=PropertyChanged}" Margin="0"
                                             ToolTip="Minimum input height range: 21-500 px"/>
                                    <TextBlock Grid.Column="3" Text="Input Max Height (%)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="4" Text="{Binding InputMaxHeightPercent, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                </Grid>

                                <!-- TUI Input Delay -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Async TUI Enter Delay (ms)" VerticalAlignment="Center" ToolTip="Time to wait before sending physical Enter key to bypass React Ink/Node.js render blocking."/>
                                    <TextBox Grid.Column="1" Text="{Binding TerminalInputDelayMs, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="0" TextAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="(Default: 500. Use 500+ for slow setups/Node.js CLIs)" VerticalAlignment="Center" Foreground="#888888" Margin="10,0,0,0"/>
                                </Grid>

                                <!-- Submit Trigger Mode -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Submit Trigger Mode" VerticalAlignment="Center" ToolTip="Choose between DoubleEnter (wait 400ms to group consecutive returns) or SingleEnter (instantly submit on Return). Shift+Enter is universally treated as newline."/>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableSubmitModes}" SelectedItem="{Binding SubmitTriggerMode}" Margin="0"/>
                                </Grid>

                                <!-- Default Startup Command -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Default Startup Command" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding DefaultStartupCommand, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                </Grid>

                                <!-- Input Watermark Format -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Input Watermark Format" VerticalAlignment="Center"/>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding InputWatermarkFormat, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                        <Button Grid.Column="1" Content="Default" 
                                                Command="{Binding ResetInputWatermarkFormatCommand}"
                                                ToolTip="Restore Default Format: [{TerminalVoiceName_or_TerminalName}] a beautiful day"
                                                Background="#3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#555555"
                                                Padding="8,2" Margin="5,0,0,0"/>
                                    </Grid>
                                </Grid>

                                <!-- Task Completion Alerts -->
                                <Grid Margin="0,12,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="186"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="── Task Completion Alerts ──"
                                               FontWeight="SemiBold"
                                               Foreground="#FFD700"
                                               VerticalAlignment="Center"
                                               Margin="0"/>
                                    <Border Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="5"
                                            Background="#252526"
                                            BorderBrush="#3E3E42"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,4"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Margin="0,4,0,0">
                                        <StackPanel>
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          Content="Allow sound reminders after tasks are completed"
                                                          IsChecked="{Binding EnableAllTaskAlerts}"
                                                          Foreground="White"
                                                          VerticalAlignment="Center"
                                                          Margin="0"/>
                                                <TextBlock Grid.Column="2"
                                                            Text="Monitor Scan Interval (sec)"
                                                            ToolTip="Shared polling interval for both per-terminal completion checks and all-terminals idle scans."
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,10,0"/>
                                                <TextBox Grid.Column="3"
                                                          Text="{Binding TaskCompletionCheckIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0"
                                                          TextAlignment="Center"
                                                          VerticalContentAlignment="Center"/>
                                                <TextBlock Grid.Column="4"
                                                            Text="(Default: 60 seconds)"
                                                            VerticalAlignment="Center"
                                                            Foreground="#888888"
                                                            Margin="10,0,0,0"
                                                            TextWrapping="Wrap"/>
                                            </Grid>

                                            <Grid Margin="0,8,0,0" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="170"/>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="72"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="72"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="TTS Voice"
                                                           ToolTip="Choose one of the installed Windows system voices."
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <ComboBox Grid.Column="1"
                                                          ItemsSource="{Binding AvailableSpeechVoices}"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="VoiceName"
                                                          SelectedValue="{Binding TtsVoiceName, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="TTS Rate (-10..10)"
                                                           ToolTip="0 is normal speed. Negative values are slower, positive values are faster."
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="4"
                                                         Text="{Binding TtsRate, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="0"
                                                         TextAlignment="Center"
                                                         VerticalContentAlignment="Center"/>
                                                <TextBlock Grid.Column="5"
                                                           Text="(Default: 0)"
                                                           VerticalAlignment="Center"
                                                           Foreground="#888888"
                                                           Margin="10,0,0,0"/>
                                                <TextBlock Grid.Column="7"
                                                           Text="TTS Volume (0..100)"
                                                           ToolTip="Per-app speech volume. Still affected by Windows master/output volume."
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="8"
                                                         Text="{Binding TtsVolume, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="0"
                                                         TextAlignment="Center"
                                                         VerticalContentAlignment="Center"/>
                                                <TextBlock Grid.Column="9"
                                                           Text="(Default: 100)"
                                                           VerticalAlignment="Center"
                                                           Foreground="#888888"
                                                           Margin="10,0,0,0"/>
                                            </Grid>
                                        </StackPanel>
                                     </Border>

                                    <Border Grid.Row="2"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="5"
                                            Background="#252526"
                                            BorderBrush="#3E3E42"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,8"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Margin="0,8,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="0"
                                                           Text="Wait For User Input Keywords"
                                                           ToolTip="One keyword per line. English and Chinese are both supported. Prefer precise phrases over overly broad single words."
                                                           Margin="0,0,0,4"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Row="0"
                                                        Grid.Column="1"
                                                        Content="Default"
                                                        Command="{Binding ResetWaitForUserInputKeywordsCommand}"
                                                        Background="#3E3E42"
                                                        Foreground="White"
                                                        BorderThickness="1"
                                                        BorderBrush="#555555"
                                                        Padding="8,2"
                                                        Margin="8,0,0,4"
                                                        VerticalAlignment="Center"/>

                                                <TextBox Grid.Row="1"
                                                         Grid.Column="0"
                                                         Grid.ColumnSpan="2"
                                                         Text="{Binding WaitForUserInputKeywords, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Height="88"
                                                         Margin="0"/>
                                            </Grid>

                                            <Grid Grid.Column="2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="0"
                                                           Text="Task Failure Keywords"
                                                           ToolTip="One keyword per line. If any recent tail line matches, the round is marked failed, it will not count as completed, and all-idle completion alerts will ignore that terminal."
                                                           Margin="0,0,0,4"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Row="0"
                                                        Grid.Column="1"
                                                        Content="Default"
                                                        Command="{Binding ResetTaskFailureKeywordsCommand}"
                                                        Background="#3E3E42"
                                                        Foreground="White"
                                                        BorderThickness="1"
                                                        BorderBrush="#555555"
                                                        Padding="8,2"
                                                        Margin="8,0,0,4"
                                                        VerticalAlignment="Center"/>

                                                <TextBox Grid.Row="1"
                                                         Grid.Column="0"
                                                         Grid.ColumnSpan="2"
                                                         Text="{Binding TaskFailureKeywords, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Height="88"
                                                         Margin="0"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Padding="14" VerticalAlignment="Stretch">
                                        <StackPanel>
                                            <TextBlock Text="Single Terminal Completion" FontWeight="SemiBold" Foreground="#FFD700" Margin="0,0,0,12"/>

                                            <CheckBox Content="Enable Single Terminal Completion TTS"
                                                      IsChecked="{Binding EnableTaskCompletionTts}"
                                                      Foreground="White" Margin="0,0,0,12"/>

                                            <TextBlock Text="Single TTS Template" ToolTip="Use {TerminalVoiceName_or_TerminalName} to prefer Terminal Voice Name and fall back to Terminal Name." Margin="0,0,0,4"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding TaskCompletionTtsTemplate, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                                <Button Grid.Column="1" Content="Default"
                                                        Command="{Binding ResetTaskCompletionTtsTemplateCommand}"
                                                        Background="#3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#555555"
                                                        Padding="8,2" Margin="5,0,0,0"/>
                                                <Button Grid.Column="2" Content="Preview"
                                                        Command="{Binding PreviewTaskCompletionTtsCommand}"
                                                        ToolTip="Play the current single-terminal TTS template with the selected voice, rate, and volume."
                                                        Background="#3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#555555"
                                                        Padding="8,2" Margin="5,0,0,0"/>
                                            </Grid>

                                            <CheckBox Content="Enable Single Terminal Failure TTS"
                                                      IsChecked="{Binding EnableTaskFailureTts}"
                                                      Foreground="White"
                                                      Margin="0,0,0,8"/>

                                            <TextBlock Text="Failure TTS Template" Margin="0,0,0,4"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding TaskFailureTtsTemplate, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                                <Button Grid.Column="1" Content="Default"
                                                        Command="{Binding ResetTaskFailureTtsTemplateCommand}"
                                                        Background="#3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#555555"
                                                        Padding="8,2" Margin="5,0,0,0"/>
                                                <Button Grid.Column="2" Content="Preview"
                                                        Command="{Binding PreviewTaskFailureTtsCommand}"
                                                        ToolTip="Play the current single-terminal failure TTS template with the selected voice, rate, and volume."
                                                        Background="#3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#555555"
                                                        Padding="8,2" Margin="5,0,0,0"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Stable Tail Threshold (min)" ToolTip="After busy markers disappear, the latest tail snapshot must remain unchanged for this many minutes before single-terminal completion is announced." Margin="0,0,0,4"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding TaskCompletionStableThresholdMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0" TextAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="(Default: 2 minutes)" VerticalAlignment="Center" Foreground="#888888" Margin="10,0,0,0" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Tail Lines to Inspect" ToolTip="Only the latest N lines are read when checking for busy/idle state." Margin="0,0,0,4"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding TaskCompletionTailLineCount, UpdateSourceTrigger=PropertyChanged}" Margin="0" TextAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="(Default: 20 lines)" VerticalAlignment="Center" Foreground="#888888" Margin="10,0,0,0" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>

                                            <CheckBox Content="Pause Auto Draft Queue When User Input Is Needed"
                                                      IsChecked="{Binding EnableWaitForUserInputGuard}"
                                                      ToolTip="If the terminal tail suggests the model is waiting for your confirmation, auto draft sending pauses and completion alerts do not treat the round as finished."
                                                      Foreground="White"
                                                      Margin="0,12,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Padding="14" VerticalAlignment="Stretch">
                                        <StackPanel>
                                            <TextBlock Text="All Terminals Idle" FontWeight="SemiBold" Foreground="#FFD700" Margin="0,0,0,12"/>

                                            <CheckBox Content="Voice Alert When All Main-Window Terminals Become Idle"
                                                      IsChecked="{Binding EnableAllTerminalsIdleVoiceAlert}"
                                                      Foreground="White" Margin="0,0,0,8"/>

                                            <CheckBox Content="Popup Alert When All Main-Window Terminals Become Idle"
                                                      IsChecked="{Binding EnableAllTerminalsIdlePopupAlert}"
                                                      Foreground="White" Margin="0,0,0,12"/>

                                            <TextBlock Text="All Idle Alert Template" Margin="0,0,0,4"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding AllTerminalsIdleTemplate, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                                <Button Grid.Column="1" Content="Default"
                                                        Command="{Binding ResetAllTerminalsIdleTemplateCommand}"
                                                        Background="#3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#555555"
                                                        Padding="8,2" Margin="5,0,0,0"/>
                                                <Button Grid.Column="2" Content="Preview"
                                                        Command="{Binding PreviewAllTerminalsIdleTemplateCommand}"
                                                        ToolTip="Play the current all-idle alert template with the selected voice, rate, and volume."
                                                        Background="#3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#555555"
                                                        Padding="8,2" Margin="5,0,0,0"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="All Idle Threshold (min)" ToolTip="How long the last N lines must stay unchanged before a terminal counts as idle." Margin="0,0,0,4"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding AllTerminalsIdleThresholdMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0" TextAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="(Default: 5 minutes)" VerticalAlignment="Center" Foreground="#888888" Margin="10,0,0,0" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="All Idle Voice Repeat (min)" ToolTip="While the idle alert window stays open, voice reminders repeat at this interval." Margin="0,0,0,4"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding AllTerminalsIdleVoiceRepeatMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0" TextAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="(Default: 30 minutes)" VerticalAlignment="Center" Foreground="#888888" Margin="10,0,0,0" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Text="── Remote Web Console ──" FontWeight="SemiBold" Margin="0,12,0,8" Foreground="#FFD700"/>

                                <Border Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="240"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <Grid Margin="0,0,0,6" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="72"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          Content="Enable Remote Web Console"
                                                          IsChecked="{Binding EnableRemoteWebConsole}"
                                                          Foreground="White"
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Protocol" VerticalAlignment="Center"/>
                                                <ComboBox Grid.Column="3"
                                                          Height="28"
                                                          Margin="0"
                                                          VerticalAlignment="Center"
                                                          ItemsSource="{Binding AvailableRemoteProtocolModes}"
                                                          SelectedItem="{Binding RemoteProtocolMode}"/>
                                                <TextBlock Grid.Column="5" Text="Bind Address" VerticalAlignment="Center" ToolTip="Use 0.0.0.0 to listen on all network interfaces. The access URL below will automatically show the best detected IPv4 address for this machine."/>
                                                <TextBox Grid.Column="6"
                                                         Height="28"
                                                         Margin="0"
                                                         VerticalAlignment="Center"
                                                         Text="{Binding RemoteBindAddress, UpdateSourceTrigger=PropertyChanged}"
                                                         VerticalContentAlignment="Center"/>
                                                <TextBlock Grid.Column="8" Text="Port" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="9"
                                                         Height="28"
                                                         Margin="0"
                                                         VerticalAlignment="Center"
                                                         Text="{Binding RemotePort, UpdateSourceTrigger=PropertyChanged}"
                                                         TextAlignment="Center"
                                                         VerticalContentAlignment="Center"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,6" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="158"/>
                                                    <ColumnDefinition Width="72"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="146"/>
                                                    <ColumnDefinition Width="72"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="138"/>
                                                    <ColumnDefinition Width="72"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="72"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Session Idle Timeout (min)" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding RemoteSessionTimeoutMinutes, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="Cookie Lifetime (days)" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="4" Text="{Binding RemoteCookieLifetimeDays, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                                <TextBlock Grid.Column="6" Text="Max Login Attempts" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="7" Text="{Binding RemoteMaxLoginAttempts, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                                <TextBlock Grid.Column="9" Text="Login Lockout (min)" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="10" Text="{Binding RemoteLoginLockoutMinutes, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,6" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="220"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="180"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="New Access Password"
                                                           VerticalAlignment="Center"
                                                           ToolTip="Leave both password boxes empty to keep the current password. Input is shown as plain text in the current session and is cleared after save or reopen."/>
                                                <TextBox Grid.Column="1"
                                                         Tag="Primary"
                                                         TextChanged="RemotePasswordTextBox_TextChanged"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="Confirm Password"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="4"
                                                         Tag="Confirm"
                                                         TextChanged="RemotePasswordTextBox_TextChanged"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="72"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Access URL"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding RemoteAccessUrl, Mode=OneWay}"
                                                         IsReadOnly="True"
                                                         ToolTip="Readonly browser access URL. Root path is intentionally disabled in the current build."/>
                                                <Button Grid.Column="3"
                                                        Height="28"
                                                        Content="Copy"
                                                        Click="CopyRemoteAccessUrl_Click"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="230"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Grid.RowSpan="3"
                                                           Text="{Binding RemotePasswordStatusText}"
                                                           Foreground="#CCCCCC"
                                                           VerticalAlignment="Top"
                                                           Margin="0,2,0,0"/>
                                                <TextBlock Grid.Column="1"
                                                           Grid.Row="0"
                                                           Text="Only /remote/ is valid in the current build. Root path is intentionally disabled. Wildcard bind addresses prefer a real LAN adapter with gateway access and automatically downgrade common virtual adapters such as WSL, VMware, Hyper-V, VPN, and Wintun. HTTPS is reserved for a future version and will not start the remote host yet."
                                                           Foreground="#888888"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Top"/>
                                                <TextBlock Grid.Column="1"
                                                           Grid.Row="1"
                                                           Margin="0,4,0,0"
                                                           Foreground="#888888"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Top">
                                                    <Run Text="Cross-network access option: Tailscale "/>
                                                    <Hyperlink NavigateUri="https://tailscale.com/"
                                                               RequestNavigate="TailscaleLink_Click">https://tailscale.com/</Hyperlink>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1"
                                                           Grid.Row="2"
                                                           Margin="0,4,0,0"
                                                           Foreground="#888888"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Top">
                                                    <Run Text="Cross-network access option: frp / frpc "/>
                                                    <Hyperlink NavigateUri="https://github.com/fatedier/frp"
                                                               RequestNavigate="FrpLink_Click">https://github.com/fatedier/frp</Hyperlink>
                                                </TextBlock>
                                            </Grid>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Background="#1F1F20"
                                                BorderBrush="#3E3E42"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="12"
                                                Width="240"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top">
                                            <StackPanel>
                                                <TextBlock Text="Scan URL on Phone"
                                                           Foreground="#CCCCCC"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,8"/>
                                                <Border Background="White"
                                                        BorderBrush="#555555"
                                                        BorderThickness="1"
                                                        Padding="12"
                                                        HorizontalAlignment="Center">
                                                    <Image Source="{Binding RemoteAccessQrCodeImage, Mode=OneWay}"
                                                           Width="168"
                                                           Height="168"
                                                           Stretch="Uniform"
                                                           SnapsToDevicePixels="True"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                                <TextBlock Text="Use your phone camera or any QR app."
                                                           Foreground="#888888"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Terminal History Settings -->
                                <TextBlock Text="── Command Sended History ──" FontWeight="SemiBold" Margin="0,12,0,8" Foreground="#FFD700"/>

                                <!-- History Retention Count -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="History Retention Limit (Count)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding HistoryRetentionCount, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                    <TextBlock Grid.Column="3" Text="Max History Filename Length" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="4" Text="{Binding HistoryFileNameMaxLength, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                </Grid>

                                <!-- Time Zone Offset -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Timezone Offset" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{Binding AvailableTimeZones}" 
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Offset"
                                              SelectedValue="{Binding TimeZoneOffset, UpdateSourceTrigger=PropertyChanged}" 
                                              Margin="0" />
                                </Grid>

                                <!-- Clipboard Conversion Settings -->
                                <TextBlock Text="── Clipboard Conversion ──" FontWeight="SemiBold" Margin="0,12,0,8" Foreground="#FFD700"/>
                                
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              Content="Enable Clipboard Image to Text/Markdown Conversion" 
                                              IsChecked="{Binding ClipboardConversionEnabled}"
                                              Foreground="White" Margin="0"/>
                                    <TextBlock Grid.Column="2" Text="Output Format" VerticalAlignment="Center" Margin="0"/>
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding AvailableOutputFormats}" 
                                              SelectedItem="{Binding ClipboardOutputFormat}" 
                                              Margin="0"/>
                                </Grid>

                                <!-- 图片保存目录 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Image Save Directory" VerticalAlignment="Center"/>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding ClipboardImageDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                        <Button Grid.Column="1" Content="Browse" 
                                                Command="{Binding BrowseClipboardImageDirectoryCommand}"
                                                ToolTip="Browse Folder"
                                                Background="#3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#555555"
                                                Padding="8,2" Margin="5,0,0,0"/>
                                        <Button Grid.Column="2" Content="Clear"
                                                Click="ClearImageDirectory_Click"
                                                ToolTip="Clear all image files in directory"
                                                Background="#660000" Foreground="White" BorderThickness="1" BorderBrush="#555555"
                                                Padding="8,2" Margin="5,0,0,0"/>
                                    </Grid>
                                </Grid>

                                <!-- 图片输出格式 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Image Output Format" VerticalAlignment="Center"/>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding ClipboardImageFormat, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                        <Button Grid.Column="1" Content="Default" 
                                                Command="{Binding ResetClipboardImageFormatCommand}"
                                                ToolTip="Restore Default Format: Image attached [{fullpath}{time}{-XXX}.{ext}]"
                                                Background="#3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#555555"
                                                Padding="8,2" Margin="5,0,0,0"/>
                                    </Grid>
                                </Grid>

                                <!-- Auto Backup System -->
                                <TextBlock Text="── Auto Backup Para ──" FontWeight="SemiBold" Margin="0,12,0,8" Foreground="#FFD700"/>

                                <Grid Margin="0,5,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              Content="Enable Auto Backup" 
                                              IsChecked="{Binding EnableAutoBackup}"
                                              Foreground="White"
                                              VerticalAlignment="Center"
                                              Margin="0"/>
                                    <TextBlock Grid.Column="2" Text="Max Backups Retained" VerticalAlignment="Center" ToolTip="Maximum number of auto backup files kept (1-1000)" Margin="0"/>
                                    <TextBox Grid.Column="3" Text="{Binding MaxBackupsRetained, UpdateSourceTrigger=PropertyChanged}" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="Backup Interval (minutes)" VerticalAlignment="Center" ToolTip="Minimum minutes between consecutive backups (1-60)" Margin="0"/>
                                    <TextBox Grid.Column="6" Text="{Binding BackupIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0" VerticalAlignment="Center"/>
                                </Grid>

                                <CheckBox Content="Run at Startup (Launch via Startup Folder)" 
                                          IsChecked="{Binding RunAtStartup}"
                                          Foreground="White" Margin="0,12,0,8"/>
                                <CheckBox Content="Start Minimized When Launched at Windows Startup"
                                          IsChecked="{Binding StartMinimizedWhenLaunchedAtStartup}"
                                          ToolTip="Only affects launches triggered by the Startup Folder shortcut. Manual launches keep their normal initial window state."
                                          Foreground="White" Margin="0,0,0,8"/>
                                <CheckBox Content="Minimize Main Window to Tray"
                                          IsChecked="{Binding MinimizeMainWindowToTray}"
                                          ToolTip="Only the main window hides to the tray when minimized. Other windows keep their normal minimize behavior."
                                          Foreground="White" Margin="0,0,0,8"/>
                                <CheckBox Content="Close Main Window to Tray Instead of Exit"
                                          IsChecked="{Binding CloseMainWindowToTrayInsteadOfExit}"
                                          ToolTip="When enabled, closing the main window hides it to the tray instead of exiting. Use the tray icon menu to exit or restart."
                                          Foreground="White" Margin="0,0,0,12"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DataTemplate>

                        <!-- Template: Terminal Settings -->
                        <DataTemplate DataType="{x:Type models:TerminalConfig}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,15,0">
                                    <TextBlock Text="Terminal Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                                <!-- Terminal Name -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Terminal Name" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Terminal Voice Name" VerticalAlignment="Center" ToolTip="Used by task-completion voice alerts. Leave blank to fall back to Terminal Name."/>
                                    <TextBox Grid.Column="1" Text="{Binding TerminalVoiceName, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Message History Save to Folder"
                                               VerticalAlignment="Center"
                                               ToolTip="Folder under history used for this terminal. Leave blank to use Terminal Name."/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding TerminalHistorySaveFolder, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Auto Draft Queue"
                                               VerticalAlignment="Center"
                                               ToolTip="When enabled, this terminal automatically sends the next draft after each task completion until the draft queue is empty."/>
                                    <CheckBox Grid.Column="1"
                                              Content="Enable Auto Submit Draft Queue On Completion"
                                              IsChecked="{Binding EnableAutoSubmitDraftQueueOnCompletion}"
                                              Foreground="White"
                                              VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Group Name -->
                                <Grid Margin="0,0,0,8" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Group Name (Folder)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding GroupName, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                </Grid>

                                <!-- Shell Type -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Shell Type" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" 
                                              SelectedValue="{Binding ShellType, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Tag"
                                              Margin="0">
                                        <ComboBoxItem Content="cmd.exe" Tag="cmd.exe"/>
                                        <ComboBoxItem Content="powershell.exe" Tag="powershell.exe"/>
                                        <ComboBoxItem Content="pwsh.exe" Tag="pwsh.exe"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Working Directory -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Working Directory" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0"/>
                                    <Button Grid.Column="2" Content="..." Width="30" Click="BrowseWorkingDirectory_Click"
                                            ToolTip="Select Working Directory"/>
                                </Grid>

                                <CheckBox Content="Show in Main Window" IsChecked="{Binding ShowInMainWindow}" 
                                          Foreground="White" Margin="0,8,0,12"/>

                                <TextBlock Text="Startup Command" Margin="0,0,0,5"/>
                                <TextBox x:Name="StartupCommandBox" Text="{Binding StartupCommand, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="150" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" Margin="0"/>

                                <!-- 快捷插入按钮区 -->
                                <TextBlock Text="── Quick Insert ──" FontWeight="SemiBold" Margin="0,12,0,8" Foreground="#FFD700"/>

                                <!-- [sleep=1000] -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="[sleep=N]" 
                                            Click="InsertText_Click" 
                                            Tag="[sleep=1000]"
                                            Padding="8,3" MinWidth="130" Background="#2D2D30" Foreground="White" BorderThickness="1" BorderBrush="#555555"/>
                                    <TextBlock Grid.Column="1" Text="Insert delay between commands (N in ms)" 
                                               VerticalAlignment="Center" Foreground="#888888" Margin="10,0,0,0" FontSize="12"/>
                                </Grid>

                                <!-- claude resume -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="claude --resume" 
                                            Click="InsertText_Click" 
                                            Tag="claude --resume"
                                            Padding="8,3" MinWidth="130" Background="#2D2D30" Foreground="White" BorderThickness="1" BorderBrush="#555555"/>
                                    <TextBlock Grid.Column="1" Text="Prompt Claude Code to select session on startup" 
                                               VerticalAlignment="Center" Foreground="#888888" Margin="10,0,0,0" FontSize="12"/>
                                </Grid>
                            </StackPanel>

                            <!-- Notes Field -->
                            <Grid Grid.Row="1" Margin="0,15,15,80">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Notes / Remarks" Foreground="#FFD700" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Grid.Row="1" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                                         
                                <!-- Explicit Delete Terminal Button -->
                                <Button Grid.Row="2" Content="Delete Terminal"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Foreground="#FF4D4D" Background="Transparent" BorderBrush="#FF4D4D" BorderThickness="1"
                                        Margin="0,20,0,0" Padding="40,10" HorizontalAlignment="Left" Width="200" 
                                        FontWeight="Bold" FontSize="14" Cursor="Hand"/>
                            </Grid>
                        </Grid>
                    </DataTemplate>

                </ContentControl.Resources>
            </ContentControl>
        </Border>

        <!-- Footer Row -->
        <Grid Grid.Row="1" Grid.Column="2" Margin="20,10,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Cursor="Hand">
                <Hyperlink NavigateUri="https://github.com/eckalhub/TerminalShell" RequestNavigate="Copyright_Click"
                           Foreground="#6BB5FF" TextDecorations="Underline">
                    https://github.com/eckalhub/TerminalShell
                </Hyperlink>
            </TextBlock>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Click="SaveOnlyButton_Click"
                    Margin="0,0,10,0" Padding="20,10"
                    Background="#2D2D30" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

                <Button Content="Save &amp; Close" Click="SaveButton_Click"
                    Padding="20,10"
                    Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

